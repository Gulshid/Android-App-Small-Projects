<?xml version="1.0" encoding="utf-8"?>
<!--
    layout/activity_main.xml — Portrait layout (phones)
    Uses ConstraintLayout with weighted GridLayout for responsive button grid.
    Buttons use match_parent width/height within GridLayout cells for uniform sizing.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ── Display Area ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/displayContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:paddingHorizontal="@dimen/display_padding_horizontal"
        android:paddingBottom="@dimen/display_padding_bottom"
        android:background="@color/bg_display"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonGrid"
        app:layout_constraintHeight_percent="0.35">

        <!-- Secondary: expression history -->
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/expression_text"
            android:textSize="@dimen/text_expression"
            android:fontFamily="sans-serif-light"
            android:gravity="end"
            android:maxLines="2"
            android:ellipsize="start"
            android:paddingBottom="4dp"/>

        <!-- Primary: current value / result -->
        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/display_text"
            android:textSize="@dimen/text_display"
            android:fontFamily="sans-serif-thin"
            android:gravity="end"
            android:maxLines="1"
            android:ellipsize="start"/>

    </LinearLayout>

    <!-- ── Button Grid ─────────────────────────────────────────────────── -->
    <!--
        GridLayout with 5 rows × 4 columns.
        Each button uses layout_columnWeight=1 + layout_rowWeight=1
        so they stretch uniformly regardless of screen size.
    -->
    <GridLayout
        android:id="@+id/buttonGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        android:useDefaultMargins="false"
        app:layout_constraintTop_toBottomOf="@id/displayContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: C  +/-  %  ÷ -->
        <Button android:id="@+id/btnClear"
            style="@style/CalcButton.Function"
            android:text="C"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnToggleSign"
            style="@style/CalcButton.Function"
            android:text="+/-"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnPercent"
            style="@style/CalcButton.Function"
            android:text="%"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnDivide"
            style="@style/CalcButton.Operator"
            android:text="÷"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <!-- Row 2: 7  8  9  × -->
        <Button android:id="@+id/btn7"
            style="@style/CalcButton.Digit"
            android:text="7"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn8"
            style="@style/CalcButton.Digit"
            android:text="8"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn9"
            style="@style/CalcButton.Digit"
            android:text="9"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnMultiply"
            style="@style/CalcButton.Operator"
            android:text="×"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <!-- Row 3: 4  5  6  - -->
        <Button android:id="@+id/btn4"
            style="@style/CalcButton.Digit"
            android:text="4"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn5"
            style="@style/CalcButton.Digit"
            android:text="5"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn6"
            style="@style/CalcButton.Digit"
            android:text="6"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnSubtract"
            style="@style/CalcButton.Operator"
            android:text="−"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <!-- Row 4: 1  2  3  + -->
        <Button android:id="@+id/btn1"
            style="@style/CalcButton.Digit"
            android:text="1"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn2"
            style="@style/CalcButton.Digit"
            android:text="2"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn3"
            style="@style/CalcButton.Digit"
            android:text="3"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnAdd"
            style="@style/CalcButton.Operator"
            android:text="+"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <!-- Row 5: ⌫  0  .  = -->
        <Button android:id="@+id/btnBackspace"
            style="@style/CalcButton.Function"
            android:text="⌫"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btn0"
            style="@style/CalcButton.Digit"
            android:text="0"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnDecimal"
            style="@style/CalcButton.Digit"
            android:text="."
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

        <Button android:id="@+id/btnEquals"
            style="@style/CalcButton.Equals"
            android:text="="
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_width="0dp"
            android:layout_height="0dp"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>