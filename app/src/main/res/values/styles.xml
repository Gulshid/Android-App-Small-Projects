<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        CalcButton base — uses background drawable directly (not backgroundTint)
        so gradients render correctly. elevation + shadow gives Flutter card feel.
    -->
    <style name="CalcButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:layout_margin">@dimen/btn_margin</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">20dp</item>
        <!-- Shadow for depth — Flutter card effect -->
        <item name="android:elevation">@dimen/btn_elevation</item>
    </style>

    <!-- Digit: dark card -->
    <style name="CalcButton.Digit" parent="CalcButton">
        <item name="android:background">@drawable/btn_digit_ripple</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/btn_digit_text</item>
    </style>

    <!-- Function: indigo tint (C, +/-, %, ⌫) -->
    <style name="CalcButton.Function" parent="CalcButton">
        <item name="android:background">@drawable/btn_function_ripple</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/btn_function_text</item>
    </style>

    <!-- Operator: indigo→violet gradient -->
    <style name="CalcButton.Operator" parent="CalcButton">
        <item name="android:background">@drawable/btn_operator_ripple</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/btn_operator_text</item>
    </style>

    <!-- Equals: pink→coral gradient -->
    <style name="CalcButton.Equals" parent="CalcButton">
        <item name="android:background">@drawable/btn_equals_ripple</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/btn_equals_text</item>
    </style>

</resources>